# Firebase web config (optional — enables cross-device sync). These values are PUBLIC/safe to expose.
# Local dev: copy to ".env.local" and fill in. CI/Pages: set the same names as repo Variables.
# Get them from Firebase console → Project settings → Your apps → Web app → SDK setup & config.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# NOTE: the Anthropic (Claude) API key and the optional YouTube Data API key are NOT build-time env
# vars. You enter them in the app under Settings; they live only in your browser's localStorage and
# are never bundled into the deploy or synced to the cloud.

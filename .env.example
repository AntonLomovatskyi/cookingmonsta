# Firebase web config (optional — enables cross-device sync). These values are PUBLIC/safe to expose.
# Local dev: copy to ".env.local" and fill in. CI/Pages: set the same names as repo Variables.
# Get them from Firebase console → Project settings → Your apps → Web app → SDK setup & config.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# App-wide YouTube Data API key. This is a PUBLIC Google API key (same kind as the Firebase
# one) — restrict it by referrer + to "YouTube Data API v3" in Google Cloud console.
VITE_YOUTUBE_API_KEY=

# NOTE: the Anthropic (Claude) API key is NOT a build-time env var. You enter it in the app under
# Settings; it lives only in your browser's localStorage and is never bundled or synced.
